# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=SmartSync AI
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
ENCRYPTION_KEY=your-32-byte-aes-key-change-me!!

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://smartsync:smartsync@postgres:5432/smartsync

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PUBSUB_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/storage
MAX_FILE_SIZE_MB=50
# For S3:
# STORAGE_BACKEND=s3
# S3_BUCKET=smartsync-storage
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_ENDPOINT_URL=           # Leave blank for AWS; set for MinIO

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=/app/storage/faiss
OCR_ENABLED=true

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:80"]
